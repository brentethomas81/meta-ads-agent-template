# Meta Ads MCP — environment template. Copy to .env and fill in YOUR values.
# (.env is gitignored — never commit real tokens.)

# Long-lived Meta System User access token (scopes: ads_management, ads_read,
# business_management, pages_read_engagement). See SETUP.md step 1.
META_ACCESS_TOKEN=

# Default ad account (prefix with "act_")
META_DEFAULT_AD_ACCOUNT_ID=act_REPLACE_ME

# Business Portfolio ID
META_BUSINESS_ID=REPLACE_ME

# Conversions pixel / dataset ID
META_DEFAULT_PIXEL_ID=REPLACE_ME

# Optional — only needed if you generate the token via your own app
META_APP_ID=
META_APP_SECRET=

# Audit log location (absolute path recommended; the server resolves relative
# paths against its own folder).
AUDIT_DB_PATH=audit.db
