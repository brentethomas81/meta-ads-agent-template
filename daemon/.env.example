# Meta Ads Agent daemon (Slack bot) — environment template.
# Copy to .env and fill in YOUR values. (.env is gitignored.)
# In production these are set as Fly secrets instead — see SETUP.md.

# --- Slack app (SETUP.md steps 2-4) ---
SLACK_BOT_TOKEN=        # xoxb-...  (Install to Workspace)
SLACK_APP_TOKEN=        # xapp-...  (App-Level Token, scope connections:write)
SLACK_SIGNING_SECRET=   # from Basic Information → App Credentials

# --- Anthropic (the brain) ---
ANTHROPIC_API_KEY=      # sk-ant-...  (platform.claude.com → API keys)
# Optional model overrides:
# MODEL_REASONING=claude-sonnet-4-6
# MODEL_TRIAGE=claude-haiku-4-5-20251001

# --- Behavior ---
BRIEFING_HOUR=6                       # daily briefing hour (24h, local to BRIEFING_TZ)
BRIEFING_MINUTE=0
BRIEFING_TZ=America/Los_Angeles
BRIEFING_CHANNEL=                     # Slack channel ID; leave blank to DM the operator

# --- Meta (the daemon imports ../mcp/server.py, which reads these) ---
# For local runs, set these in ../mcp/.env instead. In production, set all of
# them as Fly secrets on the bot app.
# META_ACCESS_TOKEN / META_DEFAULT_AD_ACCOUNT_ID / META_BUSINESS_ID / META_DEFAULT_PIXEL_ID
